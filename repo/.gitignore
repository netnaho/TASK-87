# --- OS / editor junk ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- IDE settings ---
.idea/
.vscode/

# --- Logs / runtime dumps ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Node dependencies ---
node_modules/
**/node_modules/

# --- Build artifacts ---
dist/
build/
coverage/
.nyc_output/
*.tsbuildinfo

# --- Test artifacts ---
test-results/
playwright-report/

# --- Environment / secrets ---
# Never commit .env — it may contain real secrets.
# Copy .env.example to .env and fill in real values before running docker compose.
.env
.env.*
!.env.example
!.env.*.example

# --- Local DB / Prisma generated ---
*.db
*.db-journal
backend/prisma/dev.db
backend/prisma/dev.db-journal

# --- Uploads / sessions / caches ---
uploads/*
!uploads/.gitkeep
sessions/*
!sessions/.gitkeep
tmp/
.cache/

# --- Frontend specific ---
frontend/.vite/
frontend/dist/

# --- Backend specific ---
backend/dist/

# --- Docker / local container overrides ---
# docker-compose.override.yml is committed — it provides dev defaults for fresh clones.
# Add docker-compose.override.local.yml for personal local customisations (gitignored).
docker-compose.override.local.yml

# --- Local tool settings ---
.claude/settings.local.json
.claude/
.tmp/
CLAUDE.md