# Copy this file to .env and fill in real values before running docker compose.
#   cp .env.example .env
# Never commit .env to version control.
#
# IMPORTANT: docker-compose.yml requires JWT_SECRET and ENCRYPTION_KEY to be
# present in the environment (or in .env). If either is missing, `docker compose up`
# will abort immediately with a clear error message — there are no silent defaults.

# Required — a long, random string used to sign JWTs.
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-secret

# Required — a long, random string used as the AES-256-GCM encryption key seed.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-a-random-secret

# Optional — set to "true" only during local development when you do NOT want to
# supply real secrets. The backend will use hardcoded insecure fallback values and
# emit a loud warning on every startup. NEVER set this in staging or production.
# Note: even with this flag, JWT_SECRET and ENCRYPTION_KEY must still be present
# in the environment so docker-compose.yml can start — you may set them to any
# non-empty placeholder string when using ALLOW_INSECURE_DEV_SECRETS=true.
# ALLOW_INSECURE_DEV_SECRETS=true
